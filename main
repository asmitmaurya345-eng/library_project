from issuebook import ibook
from returnbook import rbook
from donatebook import dbook
while True:
    print("book number 1234-1334")
    if l3!=[]:
        print("list of doanted books:",l3)
    print("Enter\n1:1show all books \n2:find a book\n3:issue book\n4:return book\n5:donate book\n6:exit")
    a=int(input("Enter your choice: "))
    if a ==1:
        slib()
    elif a==2:
        fbook()
    elif a==3:
        ibook()
    elif a==4:
        rbook()
    elif a==5:
        dbook()
    elif a==6:
        break
print("thank you")